<Window x:Class="AppGlory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AppGlory.ViewModels"
        Title="Glory - Análisis de Logs DE100P"
        Height="650" Width="1300"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Header style -->
        <Style x:Key="HeaderBtn" TargetType="Button">
            <Setter Property="Padding"          Value="14,7"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Background"       Value="#1F4E79"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E75B6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExportBtn" TargetType="Button" BasedOn="{StaticResource HeaderBtn}">
            <Setter Property="Background" Value="#375623"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#548235"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#AAAAAA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Column header style for DataGrid -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#1F4E79"/>
            <Setter Property="Foreground"    Value="White"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Padding"       Value="6,4"/>
            <Setter Property="BorderBrush"   Value="#2E75B6"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── ROW 0: Title ─────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Glory — Análisis de Logs DE100P"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#1F4E79" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── ROW 1: Controls ──────────────────────────────────── -->
        <Border Grid.Row="1" Background="#F0F4F8" CornerRadius="6"
                Padding="10,8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Archivo(s):"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           FontWeight="SemiBold"/>

                <TextBox Grid.Column="1"
                         Text="{Binding FilePaths, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Padding="6,4"
                         IsReadOnly="True"
                         Background="White"
                         BorderBrush="#CCCCCC"
                         ToolTip="{Binding FilePaths}"/>

                <Button Grid.Column="2" Content="Explorar..."
                        Style="{StaticResource HeaderBtn}"
                        Margin="8,0,0,0"
                        Command="{Binding SelectFilesCommand}"/>

                <Button Grid.Column="3" Content="Analizar"
                        Style="{StaticResource HeaderBtn}"
                        Margin="8,0,0,0"
                        Command="{Binding AnalyzeCommand}"/>

                <!-- Analyzing indicator -->
                <Ellipse Grid.Column="4" Width="14" Height="14"
                         Margin="10,0,0,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#CCCCCC"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Analyzing}" Value="True">
                                    <Setter Property="Fill" Value="#FFB300"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Analyzing}" Value="False">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard/>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>
        </Border>

        <!-- ── ROW 2: DataGrid ──────────────────────────────────── -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Records}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0"
                  AlternatingRowBackground="#F7FBFF"
                  RowBackground="White"
                  SelectionMode="Extended"
                  BorderBrush="#CCCCCC" BorderThickness="1"
                  FontSize="12">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Archivo"           Binding="{Binding Archivo}"           Width="120"/>
                <DataGridTextColumn Header="Serie"             Binding="{Binding NumeroSerie}"        Width="90"/>
                <DataGridTextColumn Header="Versión"           Binding="{Binding Version}"            Width="90"/>
                <DataGridTextColumn Header="Fecha Primera"     Binding="{Binding FechaPrimeraStr}"    Width="145"/>
                <DataGridTextColumn Header="Veces"             Binding="{Binding VecesAparecio}"      Width="55">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Fecha Última"      Binding="{Binding FechaUltimaStr}"     Width="145"/>
                <DataGridTextColumn Header="Error Cambio Modo" Binding="{Binding ErrorCambioDeModo}"  Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Op. con Error"     Binding="{Binding OperacionesConError}" Width="95">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Error Almacenaje"  Binding="{Binding ErrorAlmacenaje}"    Width="115">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Depósitos"         Binding="{Binding Depositos}"           Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Contando"          Binding="{Binding ContandoAlmacenado}"  Width="75">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Usuarios Distintos" Binding="{Binding UsuariosStr}"        Width="160"/>
                <DataGridTextColumn Header="# Usuarios"        Binding="{Binding UsuariosCount}"       Width="75">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Recolecciones"     Binding="{Binding Recolecciones}"       Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── ROW 3: Status bar + Export ───────────────────────── -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Status}"
                       VerticalAlignment="Center"
                       Foreground="#444444"
                       FontStyle="Italic"
                       TextTrimming="CharacterEllipsis"/>

            <Button Grid.Column="1"
                    Content="Exportar a Excel"
                    Style="{StaticResource ExportBtn}"
                    Command="{Binding ExportCommand}"
                    MinWidth="130"/>
        </Grid>
    </Grid>
</Window>
